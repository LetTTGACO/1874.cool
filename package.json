{
  "name": "@1874/1874.cool",
  "version": "0.0.2",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev -p 3005",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "sync:blog-posts": "node scripts/sync-blog-posts.mjs",
    "generate:post-icons": "node scripts/generate-post-icons.mjs",
    "preview": "next build && next start",
    "typecheck": "next typegen && tsc --noEmit",
    "format:write": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build && pnpm audit --prod --audit-level high"
  },
  "dependencies": {
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-tailwindcss": "4.0.6",
    "fast-xml-parser": "5.9.3",
    "postcss": "8.5.16",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  }
}
